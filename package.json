{
  "name": "@glyph-oss/connect",
  "version": "2.0.0",
  "description": "Framework-agnostic TypeScript SDK for launching and signing Glyph deep-link requests.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glyphq/connect.git"
  },
  "homepage": "https://glyphq.org",
  "bugs": {
    "url": "https://github.com/glyphq/connect/issues"
  },
  "keywords": [
    "glyph",
    "glyphq",
    "wallet",
    "deeplink",
    "sdk",
    "typescript"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "TESTING.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "check": "bun run lint && bun run test && bun run build",
    "audit": "bun audit --audit-level=high",
    "release:notes": "node scripts/extract-changelog-notes.mjs",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "version": "changeset version",
    "prepublishOnly": "bun run check"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
